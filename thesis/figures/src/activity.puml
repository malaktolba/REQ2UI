@startuml activity
' Figure 6 - Activity Diagram (end-to-end workflow)
skinparam backgroundColor White
skinparam defaultFontName Helvetica
skinparam shadowing false
skinparam ArrowColor #2F5C8F
skinparam activity {
  BackgroundColor #F4F7FB
  BorderColor #2F5C8F
  FontColor #1B3A5B
  DiamondBackgroundColor #DCE8F6
  DiamondBorderColor #2F5C8F
}

title Req2UI - End-to-End Workflow

start
:User registers / logs in;
if (Authenticated?) then (no)
  :Show error / lockout;
  stop
else (yes)
endif
:Create or open project;
:Enter natural-language description;
if (Input valid?) then (no)
  :Show validation feedback;
  stop
else (yes)
endif

:Start pipeline (SSE);
note right
  Each stage runs on its
  routed provider; if a user
  BYOK key is set, every stage
  runs on that provider instead.
end note
partition "Stages 1-9 (Groq + Gemini, routed per stage)" {
  :Extract requirements (Groq);
  :Generate functional reqs (Gemini);
  :Generate non-functional reqs (Groq);
  :Generate security reqs - OWASP (Groq);
  :Generate functional test cases (Gemini);
  :Generate security test cases (Gemini);
  :Generate wireframe descriptions (Groq);
  :Build traceability matrix (Groq);
  :Generate UML - Mermaid (Gemini);
}
partition "Stage 10 (Gemini)" {
  :Generate design system;
  :Generate per-screen UI code;
  :Derive wireframes from generated UI;
}
:Persist artifacts to DB;

partition "Quality evaluation (GEval, LLM-as-a-Judge)" {
  :Grade SRS, UI, UML, test cases;
  :Aggregate overall score + grade;
  :Persist evaluation + stream report;
}

:User reviews artifacts & quality report;
:Refine artifacts / preview UI code;
if (Export?) then (yes)
  :Export PDF / DOCX / CSV / LaTeX;
else (no)
endif
:Return to dashboard;
stop
@enduml
