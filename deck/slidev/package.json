    "export:png": "slidev export --format png --output exports/png"
  },
  "dependencies": {
    "@slidev/cli": "^0.49.29",
    "@slidev/theme-default": "^0.25.0"
  },
  "devDependencies": {
    "playwright-chromium": "^1.45.0"
  },
  "engines": {
    "node": ">=18"
  }
}
